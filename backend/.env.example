# ---- Server ----
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# ---- Database ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=webtogether
POSTGRES_PASSWORD=webtogether
POSTGRES_DB=webtogether
DATABASE_SYNC=false
DATABASE_MIGRATIONS_RUN=true

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT (optional for MVP, but config must be present) ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ---- App ----
APP_URL=https://webtogether.app
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120
SOCKET_IO_PATH=/socket.io

# ---- Logging ----
LOG_LEVEL=debug
